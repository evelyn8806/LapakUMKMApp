<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/rlHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Eksplorasi Event"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivSearchIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_search"
            app:tint="@color/black"/>
    </RelativeLayout>

    <!-- Search & Filter Bar -->
    <LinearLayout
        android:id="@+id/llSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/rlHeader"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#F0F0F0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/text_gray" />
                <EditText
                    android:id="@+id/etSearchExploration"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:hint="Cari event atau bazar..."
                    android:textSize="14sp"
                    android:inputType="text"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/layoutFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="SEMUA"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/admin_primary"
                    android:textColor="@color/white"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterKuliner"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="KULINER"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#F5F5F5"
                    android:textColor="@color/text_gray"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterBazar"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="BAZAR"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#F5F5F5"
                    android:textColor="@color/text_gray"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterMusik"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="MUSIK"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#F5F5F5"
                    android:textColor="@color/text_gray"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Content Area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExploration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llSearch"
        android:layout_above="@+id/bottomNav"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvNoExplorationResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Tidak ada event yang ditemukan"
        android:gravity="center"
        android:textColor="@color/text_gray"
        android:visibility="gone"/>

    <!-- Bottom Navigation Bar UMKM -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        app:cardElevation="16dp"
        app:cardCornerRadius="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <LinearLayout
                android:id="@+id/navBeranda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="@color/text_gray"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Beranda"
                    android:textSize="10sp"
                    android:textColor="@color/text_gray"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/admin_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eksplorasi"
                    android:textSize="10sp"
                    android:textColor="@color/admin_primary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navNotif"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/text_gray"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifikasi"
                    android:textSize="10sp"
                    android:textColor="@color/text_gray"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/navAkun"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="@color/text_gray"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Akun"
                    android:textSize="10sp"
                    android:textColor="@color/text_gray"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
