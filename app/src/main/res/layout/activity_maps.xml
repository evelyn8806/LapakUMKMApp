    <!-- Search & Filter Bar -->
    <LinearLayout
        android:id="@+id/llSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/rlHeader"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#F0F0F0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/text_gray" />
                <EditText
                    android:id="@+id/etSearchExploration"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:hint="Cari event atau bazar..."
                    android:textSize="14sp"
                    android:inputType="text"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/layoutFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="SEMUA"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/admin_primary"
                    android:textColor="@color/white"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterKuliner"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="KULINER"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#F5F5F5"
                    android:textColor="@color/text_gray"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterBazar"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="BAZAR"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#F5F5F5"
                    android:textColor="@color/text_gray"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilterMusik"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="MUSIK"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="#F5F5F5"
                    android:textColor="@color/text_gray"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llSearch"
        android:layout_above="@+id/bottomNav">

        <!-- Maps View (Required by MapsActivity) -->
        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExploration"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false"
            android:background="#F8F9FA"
            android:visibility="gone"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvNoEventOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="32dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum Ada Event"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kota ini belum memiliki event aktif. Request sekarang?"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_gray"/>
                <Button
                    android:id="@+id/btnRequestEvent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Request Event"
                    app:backgroundTint="@color/admin_primary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="@color/white"
            app:tint="@color/admin_primary" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvNoExplorationResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Tidak ada event yang ditemukan"
        android:gravity="center"
        android:textColor="@color/text_gray"
        android:visibility="gone"/>

