<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_previous"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pembayaran"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#222222"
                android:layout_marginStart="12dp"/>

        </LinearLayout>


        <!-- EVENT CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:elevation="5dp"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvPaymentEventName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Festival Kuliner Nusantara"
                    android:textColor="#222222"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPaymentEventDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="10 - 14 Desember 2026"
                    android:textColor="#666666" />

                <TextView
                    android:id="@+id/tvPaymentBoothInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booth A12 (3x3)"
                    android:textColor="#666666" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- RINCIAN -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rincian Pembayaran"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Biaya Booth" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp225.000" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Biaya Admin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp25.000" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:background="#DDDDDD" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TOTAL"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp250.000"
                        android:textColor="#1565C0"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- METODE PEMBAYARAN -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:elevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih Metode Pembayaran"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <RadioGroup
                    android:id="@+id/radioPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="80dp">

                    <RadioButton
                        android:id="@+id/rbTransfer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@drawable/ic_transfer_small"
                        android:drawablePadding="10dp"
                        android:text="Transfer Bank" />

                    <LinearLayout
                        android:id="@+id/layoutBankOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="32dp"
                        android:visibility="gone">

                        <Spinner
                            android:id="@+id/spinnerBank"
                            android:layout_width="match_parent"
                            android:layout_height="48dp" />
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/rbDana"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawablePadding="10dp"
                        android:text="DANA"/>
                    <RadioButton
                        android:id="@+id/rbGopay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="GoPay"/>

                    <RadioButton
                        android:id="@+id/rbOvo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="OVO"/>

                    <RadioButton
                        android:id="@+id/rbShopee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ShopeePay"/>

                </RadioGroup>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- INFORMASI -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:elevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informasi Pembayaran"
                    android:textStyle="bold"
                    android:textSize="17sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="• Pembayaran dilakukan maksimal 24 jam setelah pengajuan disetujui."
                    android:textColor="#555555"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• Setelah pembayaran berhasil, status lapak akan otomatis berubah menjadi Aktif."
                    android:textColor="#555555"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• Bukti pembayaran dapat dilihat pada menu Riwayat Pembayaran."
                    android:textColor="#555555"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- BUTTON -->

        <Button
            android:id="@+id/btnBayar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="30dp"
            android:backgroundTint="#1565C0"
            android:text="Bayar Sekarang"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"/>

    </LinearLayout>

</ScrollView>