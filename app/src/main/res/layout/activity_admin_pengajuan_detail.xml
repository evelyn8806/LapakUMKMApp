<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <RelativeLayout
        android:id="@+id/headerDetail"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:elevation="2dp">
        <ImageView
            android:id="@+id/btnBackDetail"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/black"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Review Pengajuan"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/black"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerDetail"
        android:layout_above="@+id/layoutBottomActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- UMKM Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/pasar_malam"
                        app:shapeAppearanceOverlay="@style/CircleImageView"
                        android:scaleType="centerCrop"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:id="@+id/tvDetailNamaUmkm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bakso Berkah"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/black"/>
                        <TextView
                            android:id="@+id/tvDetailJenisUsaha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kuliner • Makanan"
                            android:textColor="@color/text_gray"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User Info Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Pendaftar"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">
                <include layout="@layout/item_detail_info" android:id="@+id/infoPendaftar"/>
                <include layout="@layout/item_detail_info" android:id="@+id/infoEmail"/>
                <include layout="@layout/item_detail_info" android:id="@+id/infoNIB"/>
            </LinearLayout>

            <!-- Event Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Event &amp; Lokasi"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvDetailNamaEvent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Festival Kuliner Nusantara"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="16sp"/>
                    <TextView
                        android:id="@+id/tvDetailLokasi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lapangan Banteng, Jakarta"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginVertical="12dp"/>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Harga Sewa"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvDetailHarga"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp1.500.000"
                            android:textStyle="bold"
                            android:textColor="@color/admin_primary"
                            android:textSize="15sp"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Description Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deskripsi Usaha"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvDetailDeskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kami menjual berbagai macam bakso dengan resep tradisional yang dijamin enak dan halal."
                android:textColor="@color/black"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- Document Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dokumen Terlampir"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewKtp"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F0F0F0"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:tint="@color/text_gray"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat KTP"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_gray"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewNib"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F0F0F0"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:tint="@color/text_gray"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat NIB"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_gray"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnRejectDetail"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Tolak"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F"
            app:cornerRadius="12dp"
            android:layout_marginEnd="8dp"
            android:textAllCaps="false"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnApproveDetail"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.5"
            android:text="Setujui Pengajuan"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/admin_primary"
            android:textAllCaps="false"
            android:textStyle="bold"/>
    </LinearLayout>

</RelativeLayout>
