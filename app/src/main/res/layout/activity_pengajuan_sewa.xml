<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btnBackPengajuan"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_dark"
            android:contentDescription="Back" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Pengajuan Sewa"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark" />
    </RelativeLayout>

    <!-- Step Indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStep1Circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_blue"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Usaha"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStep2Circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_gray"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/text_gray"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berkas"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStep3Circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_gray"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/text_gray"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Step 1: Data Usaha -->
            <LinearLayout
                android:id="@+id/layoutStep1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Usaha"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nama Usaha"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaUsaha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jenis Usaha"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />
                <Spinner
                    android:id="@+id/spinnerJenisUsaha"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="NIB (Opsional)"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNIB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Alamat Usaha (Opsional)"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlamatUsaha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Deskripsi Usaha"
                    android:layout_marginBottom="24dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDeskripsiUsaha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnNextToStep2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lanjut Unggah Berkas"
                    android:backgroundTint="@color/blue_primary"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- Step 2: Berkas -->
            <LinearLayout
                android:id="@+id/layoutStep2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unggah Berkas"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Silakan unggah foto KTP (Wajib) dan SIUP/NIB (Opsional)."
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <Button
                        android:id="@+id/btnPilihKTP"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pilih File KTP"
                        android:backgroundTint="@color/gray_background"
                        android:textColor="@color/text_dark"
                        android:textAllCaps="false" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:id="@+id/tvFileNameKTP"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tidak ada file"
                            android:textSize="12sp"
                            android:ellipsize="end"
                            android:maxLines="1" />
                        <ImageView
                            android:id="@+id/ivDeleteKTP"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_close_clear_cancel"
                            app:tint="#D32F2F"
                            android:visibility="gone"
                            android:contentDescription="Hapus File" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">
                    <Button
                        android:id="@+id/btnPilihNIB"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pilih File NIB/SIUP (Opsional)"
                        android:backgroundTint="@color/gray_background"
                        android:textColor="@color/text_dark"
                        android:textAllCaps="false" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:id="@+id/tvFileNameNIB"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tidak ada file"
                            android:textSize="12sp"
                            android:ellipsize="end"
                            android:maxLines="1" />
                        <ImageView
                            android:id="@+id/ivDeleteNIB"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_close_clear_cancel"
                            app:tint="#D32F2F"
                            android:visibility="gone"
                            android:contentDescription="Hapus File" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnNextToStep3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lanjut ke Review"
                    android:backgroundTint="@color/blue_primary"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- Step 3: Review -->
            <LinearLayout
                android:id="@+id/layoutStep3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ringkasan Pengajuan"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E0E0"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Item Review -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="Nama Event"
                                android:textColor="@color/text_gray"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvReviewNamaEvent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Festival Kuliner Nusantara"
                                android:textColor="@color/text_dark"
                                android:gravity="end"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="Lokasi"
                                android:textColor="@color/text_gray"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvReviewLokasi"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Alun-Alun Kota Bandung"
                                android:textColor="@color/text_dark"
                                android:gravity="end"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="Ukuran Booth"
                                android:textColor="@color/text_gray"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="3x3 m"
                                android:textColor="@color/text_dark"
                                android:gravity="end"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="Durasi"
                                android:textColor="@color/text_gray"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="10 - 12 Jan 2025 (3 hari)"
                                android:textColor="@color/text_dark"
                                android:gravity="end"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#EEEEEE"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Biaya"
                                android:textColor="@color/text_dark"
                                android:textSize="16sp" />
                            <TextView
                                android:id="@+id/tvReviewTotalBiaya"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Rp 250.000"
                                android:textColor="@color/text_dark"
                                android:textStyle="bold"
                                android:gravity="end"
                                android:textSize="18sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <CheckBox
                    android:id="@+id/cbAgreement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Saya menyatakan data yang saya isi adalah benar dan bersedia mengikuti syarat &amp; ketentuan yang berlaku."
                    android:textSize="12sp"
                    android:layout_marginBottom="24dp" />

                <Button
                    android:id="@+id/btnSubmitPengajuan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ajukan Sekarang"
                    android:backgroundTint="@color/blue_primary"
                    android:padding="12dp"
                    android:textAllCaps="false"
                    android:enabled="false" />
            </LinearLayout>

        </FrameLayout>
    </ScrollView>

</LinearLayout>