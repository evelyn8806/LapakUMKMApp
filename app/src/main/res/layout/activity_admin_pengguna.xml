<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerAdminUser"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/black"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Pengguna"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/black"/>
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_search"
            app:tint="@color/black"/>
    </RelativeLayout>

    <!-- Tabs -->
    <HorizontalScrollView
        android:id="@+id/tabsAdminUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerAdminUser"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Semua"
                android:textSize="12sp"
                app:backgroundTint="@color/admin_primary"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Admin"
                android:textSize="12sp"
                app:backgroundTint="#F5F5F5"
                android:textColor="@color/text_gray"
                android:layout_marginEnd="8dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Pelaku UMKM"
                android:textSize="12sp"
                app:backgroundTint="#F5F5F5"
                android:textColor="@color/text_gray"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabsAdminUser"
        android:layout_above="@+id/adminBottomNav"
        android:layout_marginTop="16dp">
        <LinearLayout
            android:id="@+id/containerPenggunaFull"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">
            <!-- Items injected here using item_admin_user.xml -->
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/adminBottomNav"
        layout="@layout/layout_admin_bottom_nav" />

</RelativeLayout>
