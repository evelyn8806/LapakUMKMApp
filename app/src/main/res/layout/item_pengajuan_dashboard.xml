<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivUmkm"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/pasar_malam"
            app:shapeAppearanceOverlay="@style/CircleImageView"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/ivUmkm"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvUmkmName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bakso Berkah"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvUmkmCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kuliner"
                android:textColor="@color/text_gray"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivArrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_media_play"
            app:tint="#E0E0E0"/>

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/ivArrow"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Diproses"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFB74D"
            android:background="@drawable/bg_tag_processing"/>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
